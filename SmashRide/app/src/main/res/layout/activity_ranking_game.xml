<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- FONDOS -->
    <ImageView
        android:id="@+id/background_static"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/background_stars_static" />

    <ImageView
        android:id="@+id/background_gif"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- TÍTULO CON SOMBRA (Alineado a 160dp como Win/Lose) -->
    <TextView
        android:id="@+id/ranking_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ranking_button"
        android:textColor="@color/white"
        android:textSize="42sp"
        android:fontFamily="@font/kirby_classic"
        android:shadowColor="#FF0000"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="160dp"/>

    <!-- CONTENEDOR TIPO CRISTAL (Baja automáticamente con el título) -->
    <View
        android:id="@+id/list_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:layout_marginTop="20dp"
        android:background="#CC000000"
        app:layout_constraintTop_toBottomOf="@id/ranking_title"
        app:layout_constraintBottom_toTopOf="@id/back_menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- LISTA DE ITEMS -->
    <ListView
        android:id="@+id/ranking_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        app:layout_constraintTop_toTopOf="@id/list_container"
        app:layout_constraintBottom_toBottomOf="@id/list_container"
        app:layout_constraintStart_toStartOf="@id/list_container"
        app:layout_constraintEnd_toEndOf="@id/list_container"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/back_menu"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="260dp"
        android:layout_height="65dp"
        android:text="@string/back_to_menu"
        android:textColor="@color/white"
        android:fontFamily="@font/kirby_classic"
        android:textSize="16sp"
        app:strokeColor="@color/white"
        app:strokeWidth="2dp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>