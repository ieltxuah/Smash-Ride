<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- FONDOS: Capas base -->
    <ImageView
        android:id="@+id/background_static"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/background_stars_static" />

    <ImageView
        android:id="@+id/background_gif"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Contenedor de Carga (Sobre los fondos) -->
    <LinearLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:elevation="2dp">

        <!-- Barra de carga Blanca -->
        <ProgressBar
            android:id="@+id/game_loading_progress"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="#FFFFFF" />

        <TextView
            android:id="@+id/loading_players_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_players"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/kirby_classic"
            android:textSize="20sp"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.05"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"/>

        <!-- Botón Cancelar Rojo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancel_loading_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:text="@string/cancel_action"
            android:textColor="#FF5252"
            android:fontFamily="@font/kirby_classic"
            app:strokeColor="#FF5252"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            app:rippleColor="#40FF5252"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>