<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="20dp"
    android:gravity="center"
    android:background="@drawable/rounded_dialog_bg"> <!-- Fondo redondeado -->

    <!-- Opción Vidas -->
    <LinearLayout android:id="@+id/option_lives"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true">

        <ImageView
            android:id="@+id/img_lives"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_heart" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/mode_lives" android:textStyle="bold"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Opción Tiempo -->
    <LinearLayout android:id="@+id/option_timer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackground"
        android:clickable="true">

        <ImageView
            android:id="@+id/img_timer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_clock" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/mode_timer" android:textStyle="bold"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</LinearLayout>