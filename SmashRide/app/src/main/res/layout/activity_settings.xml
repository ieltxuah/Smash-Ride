<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <!-- SECCIÓN DE USUARIO (Cabecera) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:background="@drawable/rounded_dialog_bg"
            android:padding="16dp"
            android:backgroundTint="#1E1E1E">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="25dp">

                    <EditText
                        android:id="@+id/user_name_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="STAR_USER"
                        android:fontFamily="@font/kirby_classic"
                        android:textSize="24sp"
                        android:letterSpacing="0.05"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/edittext_underline_bg"
                        android:maxLength="9"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:paddingBottom="8dp"
                        android:hint="@string/name_hint"
                        android:textColorHint="#44FFFFFF"/>

                    <!-- Icono decorativo de lápiz que indicaremos por código si se ve o no -->
                    <ImageView
                        android:id="@+id/edit_icon_hint"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginBottom="6dp"
                        android:src="@drawable/ic_mode_edit"
                        app:tint="#4CAF50"
                        android:visibility="gone"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/auth_status_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_disconnected"
                    android:fontFamily="@font/kirby_classic"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_logout_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_action"
                android:fontFamily="@font/kirby_classic"
                android:textSize="12sp"
                app:strokeColor="#4CAF50"
                android:textColor="#4CAF50"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <!-- AJUSTES DE IDIOMA -->
        <TextView
            android:id="@+id/settings_title_language_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title_language"
            android:fontFamily="@font/kirby_classic"
            android:textSize="18sp"
            android:textColor="#FFD700"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/settings_language_spinner"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/spinner_rounded_bg"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            android:popupBackground="#1E1E1E"
            android:spinnerMode="dropdown" />

        <!-- MÚSICA -->
        <TextView
            android:id="@+id/settings_label_music_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_music"
            android:fontFamily="@font/kirby_classic"
            android:textSize="18sp"
            android:textColor="#FFD700"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_music_note"
                app:tint="#888888" />

            <SeekBar
                android:id="@+id/settings_music_seekbar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:splitTrack="false"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#33FFFFFF"
                android:thumbTint="#4CAF50"
                android:max="10"
                android:progress="5"/>
        </LinearLayout>

        <!-- EFECTOS -->
        <TextView
            android:id="@+id/settings_label_effects_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_label_effects"
            android:fontFamily="@font/kirby_classic"
            android:textSize="18sp"
            android:textColor="#FFD700"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_volume_up"
                app:tint="#888888" />

            <SeekBar
                android:id="@+id/settings_effects_seekbar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:splitTrack="false"
                android:progressTint="#2196F3"
                android:progressBackgroundTint="#33FFFFFF"
                android:thumbTint="#2196F3"
                android:max="10"
                android:progress="5"/>
        </LinearLayout>

        <!-- SELECCIÓN DE COLOR -->
        <TextView
            android:id="@+id/settings_title_color_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title_color"
            android:fontFamily="@font/kirby_classic"
            android:textSize="18sp"
            android:textColor="#FFD700"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/color_carousel_rv"
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:paddingBottom="20dp"
            android:clipToPadding="false"
            android:layout_marginBottom="32dp" />

        <!-- ACCIONES FINALES -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_save_button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/save"
            android:textColor="@color/white"
            android:fontFamily="@font/kirby_classic"
            android:textSize="24sp"
            android:backgroundTint="#4CAF50"
            app:cornerRadius="16dp"
            android:layout_marginBottom="16dp"
            app:elevation="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/migrate_data_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/migrate_guest_action"
            android:fontFamily="@font/kirby_classic"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone"
            app:backgroundTint="#FF9800"
            app:cornerRadius="12dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete_data_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/delete_all_data"
            android:fontFamily="@font/kirby_classic"
            android:textColor="#FF5252"
            android:textSize="14sp"
            app:strokeColor="#FF5252"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            app:rippleColor="#40FF5252"/>

    </LinearLayout>
</ScrollView>