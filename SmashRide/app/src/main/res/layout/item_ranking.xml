<?xml version="1.0" encoding="utf-8"?>
<!-- Añadimos un pequeño margen externo para que la elevación respire -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#22FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:cardMaxElevation="8dp">

    <!-- Este Layout interno tiene un fondo negro sólido para que el "22FFFFFF" de la Card
         se vea solo como un borde fino en los bordes redondeados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:background="@drawable/shape_ranking_item"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/rank_pos"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="@font/kirby_classic" />

        <TextView
            android:id="@+id/rank_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Player Name"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/kirby_classic" />

        <TextView
            android:id="@+id/rank_kills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 Kills"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/kirby_classic" />
    </LinearLayout>
</androidx.cardview.widget.CardView>