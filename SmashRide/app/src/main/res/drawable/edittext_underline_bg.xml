<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ESTADO: EDITABLE -->
    <item android:state_enabled="true">
        <layer-list>
            <!-- Usamos insets negativos para ocultar bordes laterales y superior -->
            <!-- Dejamos el bottom en 0 para que sea el único borde visible -->
            <item android:left="-5dp" android:right="-5dp" android:top="-5dp">
                <shape>
                    <solid android:color="@android:color/transparent" />
                    <stroke
                        android:width="2dp"
                        android:color="#4CAF50" /> <!-- Color Verde -->
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- ESTADO: GUEST (Sin línea) -->
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>